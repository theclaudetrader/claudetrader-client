# claudetrader-client configuration — copy to .env and fill in. NEVER commit .env.
# Your brokerage keys stay on YOUR machine and are never sent anywhere but Alpaca.

# --- your brokerage (Alpaca) account ---
APCA_API_KEY_ID=your_key_here
APCA_API_SECRET_KEY=your_secret_here
# Paper to start (recommended). Switch to https://api.alpaca.markets only when ready.
APCA_API_BASE_URL=https://paper-api.alpaca.markets

# --- how much to allocate to copying ---
CT_CAPITAL=1000

# --- safety ---
# Dry-run by default: prints the plan, places NO orders. Set to 0 ONLY when ready.
CT_DRY_RUN=1
# Reject feeds older/newer than this many seconds (clock-skew / stale guard). 48h.
CT_MAX_AGE_SEC=172800

# --- feed source (defaults are fine; override only for testing) ---
# CT_FEED_URL=https://theclaudetrader.vercel.app/data/signals/latest.json
# CT_PINNED_PUBKEY=...   # normally read from pinned_pubkey.txt (do not change)

# --- local risk limits (defense-in-depth; even a compromised feed can't exceed these) ---
CT_MAX_WEIGHT_PER_NAME=0.25      # never put >25% of capital in one ticker
CT_MAX_ORDER_NOTIONAL=2000       # never place a single order larger than this ($)
CT_MAX_DAILY_TURNOVER=1.0        # never trade more than 100% of capital in a day
# Kill switch: create this file to halt all trading immediately.
CT_KILL_FILE=KILL
